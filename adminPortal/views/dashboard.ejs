
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <link rel="stylesheet" href="/css/style.css">
    <title>Route Rakshak | Admin Dashboard </title>
</head>
<body class="admin-dashboard">
    <nav class="admin-nav">
        <div class="menu-toggle" onclick="toggleMenu()">
            ☰
        </div>
        <div class="logo"><img src="/images/logo.png" alt="">Route Rakshak</div>
        <div class="nr admin-nr" id="navLinks">
            <a href="/admin">Home</a>
            <a href="/admin/adminComplaints">Complaints</a>
            <a href="/admin/leaderboard">Leaderboard</a>
            <a href="/admin/logout">Logout</a>
        </div>
    </nav>

    <div class="dashboard-container">
        <header class="dashboard-header">
            <h1>Admin Dashboard</h1>
        </header>
        <section class="kpi-section">
            <div class="kpi-card">
                <h3>Ward Rank</h3>
                <p>#<%= wardRank %></p>
            </div>

            <div class="kpi-card">
                <h3>Pending Complaints</h3>
                <p><%= pendingCount %></p>
            </div>

            <div class="kpi-card">
                <h3>Total Complaints</h3>
                <p><%= ward.complaintsCount %></p>
            </div>
        </section>
        <section class="analytics-section">
            <h2>Complaint Status Distribution</h2>

            <div class="chart-card">
                <canvas id="statusChart"></canvas>
            </div>
        </section>
        <section class="top-wards-section">
            <h2>Top 3 Performing Wards</h2>

            <div class="top-wards">
                <% topWards.forEach((ward, index) => { %>
                    <div class="ward-card">
                        <span class="rank">#<%= index + 1 %></span>
                        <h3>Ward <%= ward.wardNumber %></h3>
                        <p>Score: <%= ward.performanceScore %></p>
                    </div>
                <% }) %>
            </div>
            <a href="/admin/leaderboard" class="section-link">
                View Full Leaderboard →
            </a>
        </section>
        <section class="complaint-section">
            <h2>Complaints Overview</h2>

            <div class="complaint-cards">
                <div class="complaint-card">
                    <h3>Pending Complaints</h3>
                    <p><%= pendingCount %></p>
                </div>

                <div class="complaint-card">
                    <h3>Resolved Complaints</h3>
                    <p><%= completedCount %></p>
                </div>
            </div>
            <a href="/admin/adminComplaints" class="section-link">
                Manage Complaints →
            </a>
        </section>
        
    </div>
    <div id="copywright">
        <p>&copy; <span id="year"></span> ATES Squad. All rights reserved.</p>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="statusData" type="application/json">
        <%- JSON.stringify(statusCounts || {}) %>
    </script>
    <script>
    const currentYear = new Date().getFullYear();
    document.getElementById('year').textContent = currentYear;


    const statusData = JSON.parse(
        document.getElementById("statusData").textContent
    );

   

    new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
        labels: ['Pending', 'In Progress', 'Resolved', 'Completed'],
        datasets: [{
            data: [
                statusData.pending || 0,
                statusData["in-progress"] || 0,
                statusData.resolved || 0,
                statusData.completed || 0
            ],
            backgroundColor: [
                '#d87243',
                '#b05f2d',  
                '#c9a06a',  
                '#8c4a22'   
            ],
            borderWidth: 3,
            borderColor: "transparent",
            hoverOffset: 18
        }]
    },
    options: {
        responsive: true,
        cutout: '65%',
        animation: {
            animateRotate: true,
            duration: 1200
        },
        plugins: {
            legend: {
                position: 'bottom',
                labels: {
                    padding: 20,
                    font: {
                        size: 14,
                        weight: 'bold'
                    }
                }
            }
        },
    }
});

    </script>

    
    <script src="/js/script.js"></script>
</body>
</html>
        